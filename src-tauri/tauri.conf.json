{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BioMonitor",
  "version": "0.1.0",
  "identifier": "com.biomonitor.health",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BioMonitor",
        "width": 1024,
        "height": 768,
        "minWidth": 400,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://generativelanguage.googleapis.com; font-src 'self' data:"
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:biomonitor.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
